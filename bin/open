#!/usr/bin/env bash

echo "Proxy open called with args: $*"

if [ -z "$IS_IN_OPEN_WRAPPER" ] && type '/usr/bin/open' > /dev/null 2>&1; then
    echo "trying /usr/bin/open"
    IS_IN_OPEN_WRAPPER=1 /usr/bin/open "$@"
elif [ -z "$IS_IN_XDGOPEN_WRAPPER" ] && type '/usr/bin/xdg-open' > /dev/null 2>&1; then
    echo "trying /usr/bin/xdg-open"
    IS_IN_XDGOPEN_WRAPPER=1 /usr/bin/xdg-open "$@"
elif type 'kitten' > /dev/null 2>&1; then
    if [ -z "$1" ]; then
        echo "open { file | URL }"
        exit 1
    fi
    kitten @ run open "$@" > /dev/null
else
    echo "No command to open file"
    exit 1
fi
