#!/usr/bin/env bash
set -euo pipefail

while IFS= read -r file; do
    [ -z "$file" ] && continue
    [ -f "$file" ] || continue

    dir="$(dirname "$file")"
    name="$(basename "$file")"
    base="${name%.*}"

    magick "$file" -sampling-factor 4:4:4 -quality 90 "$dir/$base.jpg"
done <<< "$NAUTILUS_SCRIPT_SELECTED_FILE_PATHS"
